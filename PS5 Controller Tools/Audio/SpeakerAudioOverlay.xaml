<UserControl x:Class="PS5_Controller_Tools.SpeakerAudioOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="106"
             d:DesignWidth="300">

    <UserControl.Resources>
        <!-- STYLE DES BOUTONS DE TRANSPORT -->
        <Style x:Key="TransportButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Margin" Value="4,0,4,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#EAF4FF"/>
            <Setter Property="Background" Value="#0070C0"/>
            <Setter Property="BorderBrush" Value="#002060"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.38"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <!-- CONTENEUR PRINCIPAL DU MEDIA PLAYER -->
    <Border Width="300"
            Height="106"
            Padding="8"
            Background="Transparent"
            BorderThickness="1"
            CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition Height="15"/>
                <RowDefinition Height="20"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- ZONE INFOS DE LECTURE -->
            <Grid x:Name="PlaybackInfoPanel"
                  Grid.Row="0"
                  Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="10"/>
                </Grid.RowDefinitions>

                <!-- LIGNE TITRE DU SON EN LECTURE -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>

                    <!-- FENETRE DE DEFILEMENT DU TITRE -->
                    <Grid x:Name="PlaybackTrackViewport"
                          Grid.Column="1"
                          Margin="6,0,6,0"
                          ClipToBounds="True"
                          SizeChanged="PlaybackTrackViewport_SizeChanged">
                        <Canvas ClipToBounds="True">
                            <!-- PANNEAU MARQUEE DU TITRE -->
                            <StackPanel x:Name="PlaybackTrackMarqueePanel"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">

                                <!-- TRANSFORM DE DEFILEMENT DU TITRE -->
                                <StackPanel.RenderTransform>
                                    <TranslateTransform x:Name="PlaybackTrackNameTransform"/>
                                </StackPanel.RenderTransform>

                                <!-- TITRE DU SON EN LECTURE -->
                                <TextBlock x:Name="PlaybackTrackNameText"
                                           Text="test.wav"
                                           FontSize="8"
                                           FontWeight="SemiBold"
                                           Foreground="#002060"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"/>

                                <!-- ESPACE ENTRE LES 2 TITRES DU MARQUEE -->
                                <Border x:Name="PlaybackTrackGap"
                                        Width="20"
                                        Background="Transparent"/>

                                <!-- CLONE DU TITRE POUR LE DEFILEMENT CONTINU -->
                                <TextBlock x:Name="PlaybackTrackNameTextClone"
                                           Text="test.wav"
                                           FontSize="8"
                                           FontWeight="SemiBold"
                                           Foreground="#002060"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"/>
                            </StackPanel>
                        </Canvas>
                    </Grid>
                </Grid>

                <!-- LIGNE PROGRESSION DE LECTURE -->
                <Grid x:Name="PlaybackProgressRow"
                      Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="34"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>

                    <!-- TEMPS COURANT DE LECTURE -->
                    <TextBlock x:Name="PlaybackCurrentTimeText"
                               Grid.Column="0"
                               Text="0:00"
                               FontSize="8"
                               FontWeight="SemiBold"
                               Foreground="#002060"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>

                    <!-- ZONE DE LA PROGRESS BAR -->
                    <Grid Grid.Column="1"
                          Margin="6,0,6,0"
                          VerticalAlignment="Center">

                        <!-- FOND DE LA PROGRESS BAR -->
                        <Border x:Name="PlaybackProgressTrack"
                                Height="2"
                                CornerRadius="3"
                                Background="#D6E4F5"
                                VerticalAlignment="Center"
                                SizeChanged="PlaybackProgressTrack_SizeChanged"/>

                        <!-- REMPLISSAGE DE LA PROGRESS BAR -->
                        <Border x:Name="PlaybackProgressFill"
                                Width="0"
                                Height="2"
                                CornerRadius="3"
                                Background="#0070C0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- DUREE TOTALE DU SON -->
                    <TextBlock x:Name="PlaybackDurationText"
                               Grid.Column="2"
                               Text="0:00"
                               FontSize="8"
                               FontWeight="SemiBold"
                               Foreground="#002060"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right" Cursor=""/>
                </Grid>
            </Grid>

            <!-- LIGNE VOLUME -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="25"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="25"/>
                </Grid.ColumnDefinitions>

                <!-- LOGO VOLUME BAS -->
                <TextBlock Grid.Column="0"
                           Text="🔈"
                           FontSize="10"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"
                           Foreground="#002060"/>

                <!-- ZONE SLIDER DE VOLUME -->
                <Grid Grid.Column="1"
                      Margin="6,0,6,0"
                      VerticalAlignment="Center">
                    <!-- FOND DE LA BARRE DE VOLUME -->
                    <Border x:Name="VolumeTrack"
                            Height="2"
                            CornerRadius="3"
                            Background="#D6E4F5"
                            VerticalAlignment="Center"/>

                    <!-- REMPLISSAGE DE LA BARRE DE VOLUME -->
                    <Border x:Name="VolumeFill"
                            Width="0"
                            Height="2"
                            CornerRadius="3"
                            Background="#0070C0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"/>

                    <!-- CALQUE DE LA BULLE DE POURCENTAGE DU VOLUME -->
                    <Canvas x:Name="VolumeBubbleLayer"
                            IsHitTestVisible="False"
                            VerticalAlignment="Stretch"
                            HorizontalAlignment="Stretch"
                            Panel.ZIndex="3">

                        <!-- BULLE DU POURCENTAGE DE VOLUME -->
                        <Border x:Name="VolumeBubble"
                                Visibility="Collapsed"
                                Background="#0070C0"
                                BorderBrush="#002060"
                                BorderThickness="1"
                                CornerRadius="9"
                                Padding="6,2,6,2">

                            <!-- TEXTE DU POURCENTAGE DE VOLUME -->
                            <TextBlock x:Name="VolumePercentText"
                                       Text="50"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Canvas>

                    <!-- SLIDER DE VOLUME -->
                    <Slider x:Name="VolumeSlider"
                            Minimum="0"
                            Maximum="127"
                            Value="64"
                            SmallChange="1"
                            LargeChange="8"
                            TickFrequency="1"
                            IsMoveToPointEnabled="True"
                            Background="Transparent"
                            BorderThickness="0"
                            VerticalAlignment="Center"
                            ValueChanged="VolumeSlider_ValueChanged"
                            SizeChanged="VolumeSlider_SizeChanged"
                            PreviewMouseLeftButtonDown="VolumeSlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="VolumeSlider_PreviewMouseLeftButtonUp"
                            LostMouseCapture="VolumeSlider_LostMouseCapture">
                        <Slider.Template>
                            <ControlTemplate TargetType="Slider">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge"
                                                          Opacity="0"
                                                          Background="Transparent"
                                                          BorderThickness="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge"
                                                          Opacity="0"
                                                          Background="Transparent"
                                                          BorderThickness="0"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <!-- CURSEUR DU SLIDER DE VOLUME -->
                                            <Thumb Width="10"
                                                   Height="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid>
                                                            <Ellipse Fill="#0070C0"
                                                                     Stroke="#002060"
                                                                     StrokeThickness="1.5"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Slider.Template>
                    </Slider>
                </Grid>

                <!-- LOGO VOLUME HAUT -->
                <TextBlock Grid.Column="2"
                           Text="🔊"
                           FontSize="10"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Foreground="#002060"/>
            </Grid>

            <!-- LIGNE COMMANDES DE TRANSPORT -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>

                <!-- GROUPE DES BOUTONS PLAY / PAUSE / STOP -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="PlayButton"
                            Style="{StaticResource TransportButtonStyle}"
                            Content="▶"
                            Click="PlayButton_Click"
                            Width="20"
                            Height="12"
                            FontSize="6"
                            Margin="2,0,2,0"/>

                    <Button x:Name="PauseButton"
                            Style="{StaticResource TransportButtonStyle}"
                            Content="❚❚"
                            Click="PauseButton_Click"
                            Width="20"
                            Height="12"
                            FontSize="6"
                            Margin="2,0,2,0"/>

                    <Button x:Name="StopButton"
                            Style="{StaticResource TransportButtonStyle}"
                            Content="■"
                            Click="StopButton_Click"
                            Width="20"
                            Height="12"
                            FontSize="6"
                            Margin="2,0,2,0"/>
                </StackPanel>

                <!-- BADGE ETAT DE LECTURE -->
                <Border Grid.Column="0"
                        x:Name="PlaybackStateBadge"
                        Margin="0"
                        Padding="6,1,6,1"
                        CornerRadius="8"
                        BorderThickness="1"
                        Background="#D8F5E3"
                        BorderBrush="#97D8AF"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">

                    <!-- TEXTE ETAT DE LECTURE : STOP / WAV / PAUSE -->
                    <TextBlock x:Name="PlaybackStateText"
                               Text="STOP"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#146C43"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Grid>

            <!-- LIGNE MESSAGE AUDIO -->
            <Border Grid.Row="3"
                    x:Name="AudioStatusBorder"
                    Margin="0,8,0,0"
                    Padding="8,3,8,3"
                    Background="#F8FBFF"
                    BorderBrush="#C7D8EE"
                    BorderThickness="1"
                    CornerRadius="8">

                <!-- FENETRE DE DEFILEMENT DU MESSAGE AUDIO -->
                <Grid x:Name="AudioStatusViewport"
                      ClipToBounds="True"
                      SizeChanged="AudioStatusViewport_SizeChanged">
                    <Canvas ClipToBounds="True">

                        <!-- PANNEAU MARQUEE DU MESSAGE AUDIO -->
                        <StackPanel x:Name="AudioStatusMarqueePanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <!-- TRANSFORM DE DEFILEMENT DU MESSAGE AUDIO -->
                            <StackPanel.RenderTransform>
                                <TranslateTransform x:Name="AudioStatusTextTransform"/>
                            </StackPanel.RenderTransform>

                            <!-- MESSAGE AUDIO PRINCIPAL -->
                            <TextBlock x:Name="AudioStatusText"
                                       Text=""
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="#002060"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>

                            <!-- ESPACE ENTRE LES 2 TEXTES DU MARQUEE AUDIO -->
                            <Border x:Name="AudioStatusGap"
                                    Width="24"
                                    Background="Transparent"/>

                            <!-- CLONE DU MESSAGE AUDIO POUR DEFILEMENT CONTINU -->
                            <TextBlock x:Name="AudioStatusTextClone"
                                       Text=""
                                       FontSize="9"
                                       FontWeight="SemiBold"
                                       Foreground="#002060"
                                       VerticalAlignment="Center"
                                       TextWrapping="NoWrap"/>
                        </StackPanel>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
