<UserControl x:Class="PS5_Controller_Tools.Triggers.TriggerPressureOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="60"
             Height="60"
             IsHitTestVisible="False"
             Visibility="Collapsed">
    <Grid>
        <Grid x:Name="FillHost">
            <Grid.Clip>
                <EllipseGeometry x:Name="ClipEllipse"/>
            </Grid.Clip>

            <Path x:Name="FillPath"
                  Fill="#44002060"/>
        </Grid>

        <TextBlock x:Name="PercentText"
                   Text="0%"
                   FontSize="16"
                   FontWeight="Bold"
                   Foreground="#FF002060"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Visibility="Collapsed"/>
    </Grid>
</UserControl>
