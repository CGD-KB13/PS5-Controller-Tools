<UserControl x:Class="PS5_Controller_Tools.Triggers.AdaptiveTriggerParameterSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="104"
             Width="104"
             Height="20"
             Background="Transparent"
             SnapsToDevicePixels="True">

    <Grid Background="Transparent" Height="20" VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="9"/>
            <RowDefinition Height="11"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="ParameterLabelText"
                   Text="Label"
                   FontSize="8"
                   FontWeight="SemiBold"
                   Foreground="#0070C0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Left" Width="104"/>

        <Grid x:Name="SliderVisualHost"
              Grid.Row="1"
              Background="Transparent"
              SizeChanged="SliderVisualHost_SizeChanged">

            <Canvas x:Name="BubbleLayer"
                    IsHitTestVisible="False"
                    Panel.ZIndex="5">
                <Border x:Name="ValueBubble"
                        Visibility="Collapsed"
                        Background="#0070C0"
                        BorderBrush="#002060"
                        BorderThickness="1"
                        CornerRadius="9"
                        Padding="6,2,6,2">
                    <TextBlock x:Name="ValueBubbleText"
                               Text="0"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
            </Canvas>

            <Grid x:Name="TrackContainer"
                  Width="100"
                  Height="16"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center">
                <Border x:Name="ValueTrack"
                        Height="2"
                        Background="#D6E4F5"
                        CornerRadius="3"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"/>

                <Border x:Name="ValueFill"
                        Width="0"
                        Height="2"
                        Background="#0070C0"
                        CornerRadius="3"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"/>

                <Slider x:Name="ValueSlider"
                        Minimum="0"
                        Maximum="100"
                        Value="0"
                        SmallChange="1"
                        LargeChange="10"
                        TickFrequency="1"
                        IsMoveToPointEnabled="True"
                        Orientation="Horizontal"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        ValueChanged="ValueSlider_ValueChanged"
                        PreviewMouseLeftButtonDown="ValueSlider_PreviewMouseLeftButtonDown"
                        PreviewMouseLeftButtonUp="ValueSlider_PreviewMouseLeftButtonUp"
                        LostMouseCapture="ValueSlider_LostMouseCapture">
                    <Slider.Template>
                        <ControlTemplate TargetType="Slider">
                            <Grid Background="Transparent">
                                <Track x:Name="PART_Track"
                                       Orientation="Horizontal">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge"
                                                      Opacity="0"
                                                      Background="Transparent"
                                                      BorderThickness="0"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge"
                                                      Opacity="0"
                                                      Background="Transparent"
                                                      BorderThickness="0"/>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Width="10"
                                               Height="10">
                                            <Thumb.Template>
                                                <ControlTemplate TargetType="Thumb">
                                                    <Grid>
                                                        <Ellipse Fill="#0070C0"
                                                                 Stroke="#002060"
                                                                 StrokeThickness="1.5"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Thumb.Template>
                                        </Thumb>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                        </ControlTemplate>
                    </Slider.Template>
                </Slider>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
