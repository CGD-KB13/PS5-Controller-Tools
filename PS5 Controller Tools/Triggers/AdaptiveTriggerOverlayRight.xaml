<UserControl x:Class="PS5_Controller_Tools.Triggers.AdaptiveTriggerOverlayRight"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="150"
             d:DesignHeight="188"
             Width="150"
             Height="188"
             Background="Transparent"
             ClipToBounds="False"
             SnapsToDevicePixels="True">

    <Grid x:Name="RootSurface"
          Background="Transparent"
          ClipToBounds="False">

        <Canvas x:Name="OverlayCanvas"
                IsHitTestVisible="False"
                Panel.ZIndex="10">
            <Border x:Name="ModeBubble"
                    Visibility="Collapsed"
                    Background="#0070C0"
                    BorderBrush="#002060"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="7,2,7,2">
                <TextBlock x:Name="ModeBubbleText"
                           Text="OFF"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Canvas>

        <Grid x:Name="ContentLayout"
              Background="Transparent"
              ClipToBounds="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="104"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="14"/>
                <ColumnDefinition Width="16"/>
            </Grid.ColumnDefinitions>

            <StackPanel x:Name="ParameterStack"
                        Grid.Column="0"
                        Margin="0,4,0,0"
                        Orientation="Vertical"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"/>

            <Grid x:Name="ModeSection"
                  Grid.Column="2"
                  Grid.ColumnSpan="2"
                  Width="30"
                  Height="188"
                  VerticalAlignment="Top"
                  HorizontalAlignment="Right">
                <Grid x:Name="ModeSelectorLayout"
                      Margin="0,2,0,0"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="2"/>
                        <ColumnDefinition Width="16"/>
                    </Grid.ColumnDefinitions>

                    <UniformGrid x:Name="ModeNumbersGrid"
                                 Grid.Column="0"
                                 Width="14"
                                 Height="132"
                                 Rows="7"
                                 IsHitTestVisible="False"/>

                    <Grid x:Name="ModeTrackShell"
                          Grid.Column="2"
                          Width="16"
                          Height="132"
                          SizeChanged="ModeTrackShell_SizeChanged">
                        <Border x:Name="ModeTrack"
                                Width="2"
                                Background="#D6E4F5"
                                CornerRadius="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"/>

                        <Border x:Name="ModeFill"
                                Width="2"
                                Height="0"
                                Background="#0070C0"
                                CornerRadius="3"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"/>

                        <Slider x:Name="ModeSlider"
                                Minimum="0"
                                Maximum="6"
                                Value="0"
                                SmallChange="1"
                                LargeChange="1"
                                TickFrequency="1"
                                IsMoveToPointEnabled="True"
                                IsSnapToTickEnabled="True"
                                Orientation="Vertical"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Stretch"
                                ValueChanged="ModeSlider_ValueChanged"
                                PreviewMouseLeftButtonDown="ModeSlider_PreviewMouseLeftButtonDown"
                                PreviewMouseLeftButtonUp="ModeSlider_PreviewMouseLeftButtonUp"
                                LostMouseCapture="ModeSlider_LostMouseCapture">
                            <Slider.Template>
                                <ControlTemplate TargetType="Slider">
                                    <Grid Background="Transparent">
                                        <Track x:Name="PART_Track"
                                               Orientation="Vertical">
                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Command="Slider.DecreaseLarge"
                                                              Opacity="0"
                                                              Background="Transparent"
                                                              BorderThickness="0"/>
                                            </Track.DecreaseRepeatButton>
                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Command="Slider.IncreaseLarge"
                                                              Opacity="0"
                                                              Background="Transparent"
                                                              BorderThickness="0"/>
                                            </Track.IncreaseRepeatButton>
                                            <Track.Thumb>
                                                <Thumb Width="10"
                                                       Height="10">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Grid>
                                                                <Ellipse Fill="#0070C0"
                                                                         Stroke="#002060"
                                                                         StrokeThickness="1.5"/>
                                                            </Grid>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>
                                        </Track>
                                    </Grid>
                                </ControlTemplate>
                            </Slider.Template>
                        </Slider>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
