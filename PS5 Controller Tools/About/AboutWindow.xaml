<Window x:Class="PS5_Controller_Tools.About.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="À propos"
        Width="480"
        Height="320"
        Icon="/Assets/KB13Tran256.ico"
        Background="#F0F0F0"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True">

    <Border Background="Transparent">
        <Grid ClipToBounds="True">
            <Image x:Name="BackgroundVisual"
                   Stretch="Uniform"
                   Opacity="1.00"
                   Visibility="Collapsed"
                   IsHitTestVisible="False"/>

            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="190*"/>
                    <ColumnDefinition Width="20*"/>
                    <ColumnDefinition Width="190*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="135"/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <!-- Titre + version -->
                <StackPanel Grid.Row="0"
                            Grid.Column="0">
                    <TextBlock x:Name="ApplicationNameText"
                               Text="PS5_Controller_Tools"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                    <StackPanel>
                        <TextBlock x:Name="VersionText"
                                   FontSize="14"
                                   Margin="20,6,0,0"
                                   Foreground="#002060"/>

                        <TextBlock x:Name="VersionNum"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Margin="0,20,0,0"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="#002060"/>
                    </StackPanel>
                </StackPanel>

                <!-- Logo plus haut -->
                <Image x:Name="LogoVisual"
                       Grid.Row="0"
                       Grid.Column="2"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Margin="0,0,0,0"
                       Width="220"
                       Height="120"
                       Stretch="Uniform"
                       Panel.ZIndex="10"
                       Visibility="Collapsed"/>

                <!-- Développé par -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0">
                    <TextBlock x:Name="DeveloperTitleText"
                               Text="Développé par :"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="DeveloperValueText"
                               Text="CGD KB13"
                               Margin="20,6,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Description -->
                <StackPanel Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,56,0,0"
                            VerticalAlignment="Top" 
                            Height="70">
                    <TextBlock x:Name="DescriptionTitleText"
                               Text="Description :"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="DescriptionValueText"
                               Text="Outil de test pour manette PS5 après réparation."
                               Margin="20,6,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Email en face de la description -->
                <StackPanel Grid.Row="1"
                            Grid.Column="2"
                            VerticalAlignment="Top">
                    <TextBlock x:Name="EmailTitleText"
                               Text="Email de contact :"
                               FontSize="14"
                               FontWeight="Bold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="EmailValueText"
                               Text="christophe.kb13@gmail.com"
                               Margin="20,6,0,0"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#002060"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>