<UserControl x:Class="PS5_Controller_Tools.Vibration.VibrationMotorOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignWidth="84"
             d:DesignHeight="156"
             Width="84"
             Height="156"
             Background="Transparent">

    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="100"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Max"
                       Margin="0,0,0,2"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#002060"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>

            <Grid x:Name="SliderVisualHost"
                  Grid.Row="1"
                  Width="84"
                  Height="100"
                  SizeChanged="SliderVisualHost_SizeChanged">

                <Canvas x:Name="IntensityBubbleLayer"
                        Width="84"
                        Height="100"
                        IsHitTestVisible="False"
                        Panel.ZIndex="4">
                    <Border x:Name="IntensityBubble"
                            Visibility="Collapsed"
                            Background="#0070C0"
                            BorderBrush="#002060"
                            BorderThickness="1"
                            CornerRadius="9"
                            Padding="6,2,6,2">
                        <TextBlock x:Name="IntensityPercentText"
                                   Text="0"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Canvas>

                <Grid x:Name="TrackContainer"
                      Width="22"
                      Height="78"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Opacity="0.45">
                    <Border x:Name="IntensityTrack"
                            Width="2"
                            Background="#D6E4F5"
                            CornerRadius="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"/>

                    <Border x:Name="IntensityFill"
                            Width="2"
                            Height="0"
                            Background="#0070C0"
                            CornerRadius="3"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Bottom"/>

                    <Slider x:Name="IntensitySlider"
                            Minimum="0"
                            Maximum="100"
                            Value="0"
                            SmallChange="1"
                            LargeChange="10"
                            TickFrequency="1"
                            IsMoveToPointEnabled="True"
                            Orientation="Vertical"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"
                            ValueChanged="IntensitySlider_ValueChanged"
                            PreviewMouseLeftButtonDown="IntensitySlider_PreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="IntensitySlider_PreviewMouseLeftButtonUp"
                            LostMouseCapture="IntensitySlider_LostMouseCapture">
                        <Slider.Template>
                            <ControlTemplate TargetType="Slider">
                                <Grid Background="Transparent">
                                    <Track x:Name="PART_Track"
                                           Orientation="Vertical">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Command="Slider.DecreaseLarge"
                                                          Opacity="0"
                                                          Background="Transparent"
                                                          BorderThickness="0"/>
                                        </Track.DecreaseRepeatButton>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Command="Slider.IncreaseLarge"
                                                          Opacity="0"
                                                          Background="Transparent"
                                                          BorderThickness="0"/>
                                        </Track.IncreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Width="10"
                                                   Height="10">
                                                <Thumb.Template>
                                                    <ControlTemplate TargetType="Thumb">
                                                        <Grid>
                                                            <Ellipse Fill="#0070C0"
                                                                     Stroke="#002060"
                                                                     StrokeThickness="1.5"/>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Thumb.Template>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Slider.Template>
                    </Slider>
                </Grid>
            </Grid>

            <TextBlock Grid.Row="2"
                       Text="Min"
                       Margin="0,2,0,0"
                       FontSize="10"
                       FontWeight="SemiBold"
                       Foreground="#002060"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"/>
        </Grid>

        <CheckBox x:Name="EnableMotorCheckBox"
                  Grid.Row="1"
                  Width="15"
                  Height="14"
                  Margin="0,6,0,0"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Checked="EnableMotorCheckBox_Checked"
                  Unchecked="EnableMotorCheckBox_Unchecked"/>

    </Grid>
</UserControl>
